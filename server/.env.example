# Copy this file to .env and fill in the real values. .env is gitignored.

# Absolute path to your Obsidian vault (the folder containing Wiki/, Raw/, Outputs/, .obsidian/)
VAULT_PATH=/Users/haydencooper/Library/Mobile Documents/iCloud~md~obsidian/Documents/Hayden's Vault

# Your iCloud email (Apple ID)
ICLOUD_USERNAME=

# An app-specific password generated at https://account.apple.com/account/manage
# (Sign-In and Security -> App-Specific Passwords). Never your real Apple ID password.
ICLOUD_APP_PASSWORD=

# Comma-separated list of origins allowed to call this API. Defaults cover the
# deployed Nova OS site plus local dev — usually you don't need to change this.
# ALLOWED_ORIGINS=https://hcooper12.github.io,http://localhost:5183

# Port the server listens on.
# PORT=4173

# Interface to bind. Defaults to 127.0.0.1 (localhost only) — tailscale serve
# proxies from localhost, so the https ts.net URL still works. Set 0.0.0.0
# only if something must reach the port directly by IP (not recommended).
# HOST=127.0.0.1

# Leave unset on first run — the server will generate one and write it back here.
# API_TOKEN=
